  "scripts": {
    "test": "npm run test:unit && npm run test:bdd",
    "test:unit": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand",
    "test:coverage": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand --coverage",
    "test:bdd": "cucumber-js test/features/**/*.feature --import test/steps/**/*.js --import test/support/**/*.js -f html:reporte_bdd.html",
    "dev": "nodemon --env-file=.env src/index.js",
    "start": "node src/index.js",
    "migrate": "node --env-file=.env src/migrate.js"
  },
